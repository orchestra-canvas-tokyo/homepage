{
	"name": "svelte-homepage",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"lint:prettier": "prettier --check .",
		"lint:eslint": "eslint .",
		"format": "prettier --write .",
		"prepare": "husky",
		"precommit": "npm run check && npm run lint:prettier && npm run lint:eslint && npm run test",
		"add:concert": "npx hygen page concert",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.65.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/eslint": "^9.6.1",
		"@types/node": "^24.13.2",
		"@typescript-eslint/eslint-plugin": "^8.61.0",
		"@typescript-eslint/parser": "^8.61.0",
		"@vitest/coverage-v8": "4.1.8",
		"@vitest/ui": "4.1.8",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"svelte-meta-tags": "^5.0.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "4.1.8",
		"wrangler": "^4.100.0"
	},
	"type": "module",
	"dependencies": {
		"@splidejs/svelte-splide": "^0.2.9",
		"@types/grecaptcha": "^3.0.9",
		"@types/matter-js": "^0.20.2",
		"dayjs": "^1.11.21",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"matter-js": "^0.20.0",
		"swiper": "^12.2.0",
		"zod": "^4.4.3"
	},
	"overrides": {
		"cookie": "^1.0.2",
		"esbuild": "^0.28.1",
		"flatted": "^3.4.2"
	},
	"optionalDependencies": {
		"@cloudflare/workerd-linux-64": "1.20260613.1",
		"@img/sharp-linux-x64": "0.35.1",
		"@rollup/rollup-linux-x64-gnu": "^4.62.0"
	}
}
